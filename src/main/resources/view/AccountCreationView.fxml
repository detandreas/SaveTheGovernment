<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="budget.ui_fx.controller.AccountCreationController"
      spacing="20" alignment="CENTER">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label fx:id="createAccountLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="usernameLabel" minWidth="100"/>
        <TextField fx:id="usernameField" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="passwordLabel" minWidth="100"/>
        <PasswordField fx:id="passwordField" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="confirmPasswordLabel" minWidth="100"/>
        <PasswordField fx:id="confirmPasswordField" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="fullNameLabel" minWidth="100"/>
        <TextField fx:id="fullNameField" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="roleLabel" minWidth="100"/>
        <ComboBox fx:id="roleComboBox" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox fx:id="ministryContainer" spacing="10" alignment="CENTER">
        <Label fx:id="ministryLabel" minWidth="100"/> 
        <ComboBox fx:id="ministryComboBox" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <Label fx:id="errorLabel" textFill="red" />
    <Label fx:id="successLabel" textFill="green" />

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="createAccountButton" onAction="#handleCreateAccount" prefWidth="120"/>
        <Button fx:id="cancelButton" onAction="#handleCancel" prefWidth="120"/>
        <Button fx:id="backButton" onAction="#handleBack" prefWidth="120"/>
    </HBox>

</VBox>